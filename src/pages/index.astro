---
import { getSupabase } from '../utils/supabaseClient.js';
import { isSpam } from '../utils/antiSpam.js';
import { logLead } from '../utils/logger.js';

let messageStatus = null;
const rateLimiter = new Map();

if (Astro.request.method === "POST") {
  const formData = await Astro.request.formData();

  const clientIP = Astro.request.headers.get("x-forwarded-for") ?? "unknown";

  if (isSpam(formData, clientIP, rateLimiter)) {
    messageStatus = "Spam detectado.";
  } else {
    const supabase = getSupabase();

    const name = formData.get("name");
    const email = formData.get("email");
    const phone = formData.get("phone");
    const message = formData.get("message");

    logLead(name, email, phone);

    await supabase
      .from("leads")
      .insert([{ name, email, phone, message }]);

    const telegramMessage =
      `Novo Lead:%0A%0A` +
      `Nome: ${name}%0A` +
      `Email: ${email}%0A` +
      `Telefone: ${phone}%0A` +
      `Mensagem: ${message}`;

    await fetch(
      `https://api.telegram.org/bot${import.meta.env.TELEGRAM_BOT_TOKEN}/sendMessage?chat_id=${import.meta.env.TELEGRAM_CHAT_ID}&text=${telegramMessage}`
    );

    messageStatus = "Enviado com sucesso!";
  }
}
---

<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <link rel="stylesheet" href="/style.css" />
  <title>Landing Page Moderna</title>
  
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-76TEEQXF7S"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-76TEEQXF7S');
  </script>
</head>

<body>
  <div class="container">
    <h1>Fale Conosco</h1>

    {messageStatus && <p id="status">{messageStatus}</p>}

    <form method="POST" id="leadForm">
      <!-- Honeypot -->
      <input style="display:none" name="website" />

      <label>Nome</label>
      <input name="name" required minlength="3" />

      <label>Email</label>
      <input type="email" name="email" required />

      <label>Telefone</label>
      <input name="phone" required />

      <label>Mensagem</label>
      <textarea name="message"></textarea>

      <div class="spinner" id="spinner"></div>

      <button type="submit" id="btnSubmit">Enviar</button>
    </form>
  </div>

  <script>
    const form = document.getElementById("leadForm");
    const btn = document.getElementById("btnSubmit");
    const spinner = document.getElementById("spinner");

    form.addEventListener("submit", () => {
      btn.disabled = true;
      spinner.style.display = "block";
    });
  </script>
</body>
</html>
